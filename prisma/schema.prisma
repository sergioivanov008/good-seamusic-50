generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Artists {
  id    Int     @id @default(autoincrement())
  artist_name String  @unique
  description  String 
  photo_url String @unique
  tags Tags[]
  tracks Tracks[]
  beats Beats[]
}

model Producers {
  id Int @id @default(autoincrement())
  producer_name String  @unique
  description  String 
  photo_url String @unique
  tags Tags[]
  tracks Tracks[]
  beats Beats[]
}

model Tracks {
  id Int @id @default(autoincrement())
  cover_url String
  track_name String
  album_name String
  listens Int
  playtime Int
  like Boolean
  artist_id Int @unique
  producer_id Int @unique
  album_id Int @unique
  file_url String
  artist Artists @relation(fields: [artist_id], references: [id])
  producer Producers @relation(fields: [producer_id], references: [id])
  album Albums @relation(fields: [album_id], references: [id])
}

model Tags {
  id Int @id @default(autoincrement())
  tag_name String
  description String
  artist_id Int @unique
  producer_id Int @unique
  artist Artists @relation(fields: [artist_id], references: [id])
  producer Producers @relation(fields: [producer_id], references: [id])
}

model Beats {
  id Int @id @default(autoincrement())
  cover_url String
  beat_name String
  beatpack_name String
  listens Int
  playtime Int
  like Boolean
  artist_id Int @unique
  producer_id Int @unique
  beatpack_id Int @unique
  file_url String
  artist Artists @relation(fields: [artist_id], references: [id])
  producer Producers @relation(fields: [producer_id], references: [id])
  beatpack Beatpacks @relation(fields: [beatpack_id], references: [id])
}

model Albums {
  id Int @id @default(autoincrement())
  cover_url String
  album_name String
  description String
  plays_number Int
  duration Int
  like Boolean
  tracks Tracks[]
}

model Beatpacks {
  id Int @id @default(autoincrement())
  cover_url String
  beatpack_name String
  description String
  plays_number Int
  like Boolean
  beats Beats[]
}