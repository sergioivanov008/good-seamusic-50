generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  superuser
}

enum Level {
  none
  bot
  full
}

model User {
  id    Int     @id @default(autoincrement())
  username String  @unique
  description  String
  email  String @unique
  password String
  picture_url String @unique
  access_level  Role
  telegram_id Int @unique
  premium_level Level
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_active Boolean
  is_adult Boolean
  is_verified Boolean
  artist_id Int @unique
  producer_id Int @unique
  license_id Int @unique
  artist_profile String
  producer_profile String
  licenses Licence?
  followed_squads Squad[]
  followed_artists Artist[]
  coauthored_playlists String
  saved_playlists String
  followed_producers Producer[]
  saved_albums Album[]
  followed_tags String
}

model Artist {
  id Int @id @default(autoincrement())
  username User @relation(fields: [id], references: [artist_id])
  description String
  picture_url String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_available Boolean
  tags Tag[]
  albums String
  squads Squad[]
  tracks Track[]
  followers String
}

model Producer {
  id Int @id @default(autoincrement())
  username User @relation(fields: [id], references: [producer_id])
  description String
  picture_url String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_available Boolean
  followers String
  beats Beat[]
  squads Squad[]
  tags Tag[]
  beatpacks Beatpack[]
  soundkits Soundkit[]
}

model Licence {
  id Int @id @default(autoincrement())
  title String
  text String
  description String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  author User @relation(fields: [id], references: [license_id])
}

model Squad {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  followers String
  creator User[]
  applicant_artists String
  applicant_producers String
  artists Artist[]
  producers Producer[]
}

model Playlist {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  creator String
  authors String
  beats String
  tracks String
  tags Tag[]
}

model Album {
  id Int @id @default(autoincrement())
  username User @relation(fields: [id], references: [producer_id])
  description String
  picture_url String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_available Boolean
  followers String
  beats String
  squads String
  tags Tag[]
  beatpacks String
  soundkits String
}

model Tag {
  id Int @id @default(autoincrement())
  name String @unique
  artists Artist[]
  producers Producer[]
  albums Album[]
  beats Beat[]
  beatpacks Beatpack[]
  soundkits Soundkit[]
  tracks Track[]
  playlists Playlist[]
}

model Track {
  id Int @id @default(autoincrement())
  title String
  description String
  file_url String @unique
  price Int
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  artists Artist[]
  album String
  license String
  producers String
  comments String
  tags Tag[]
}

model Beat {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  file_url String @unique
  price Int
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  comments String
  license String
  producers Producer[]
  tags Tag[]
  beatpacks Beatpack[]
}

model Beatpack {
  id Int @id @default(autoincrement())
  title String
  description String
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  producers Producer[]
  beats Beat[]
  tags Tag[]
}

model Soundkit {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  file_url String @unique
  price Int
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  license String
  producers Producer[]
  beats String
  tags Tag[]
}

model Comment {
  id Int @id @default(autoincrement())
  text String
  author_id Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  author String
}

model Chat {
  id Int @id @default(autoincrement())
  messages String
  participants String
}

model Messages {
  id Int @id @default(autoincrement())
  text String
  author_id Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  chat String
  author String
}

model Notification {
  id Int @id @default(autoincrement())
  title String
  description String
  reciever String
  created_at DateTime @default(now())
}