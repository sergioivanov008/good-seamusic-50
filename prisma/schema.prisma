generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  superuser
}

enum Level {
  none
  bot
  full
}

model User {
  id    Int     @id @default(autoincrement())
  username String  @unique
  description  String 
  email  String @unique
  password String
  picture_url String @unique
  access_level  Role
  followed_artists Artist?
  followed_producers Producer?
  is_active Boolean
  is_verified Boolean
  is_adult Boolean
}

model Artist {
  user User @relation(fields: [user_id], references: [id])
  user_id Int @unique
  description String
  picture_url String
}

model Producer {
  user User @relation(fields: [user_id], references: [id])
  user_id Int @unique
  description String
  picture_url String @unique
}

model Licence {
  id Int @id @default(autoincrement())
  title String
  text String
  description String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Squad {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  followers String
  applicant_artists String
  applicant_producers String
}

model Playlist {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  creator String
  authors String
  beats String
  tracks String
  tags Tag[]
}

model Album {
  id Int @id @default(autoincrement())
  description String
  picture_url String @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_available Boolean
  followers String
  beats String
  squads String
  tags Tag[]
  beatpacks String
  soundkits String
}

model Tag {
  id Int @id @default(autoincrement())
  name String @unique
  albums Album[]
  beats Beat[]
  beatpacks Beatpack[]
  soundkits Soundkit[]
  tracks Track[]
  playlists Playlist[]
}

model Track {
  id Int @id @default(autoincrement())
  title String
  description String
  file_url String @unique
  price Int
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  album String
  license String
  producers String
  comments String
  tags Tag[]
}

model Beat {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  file_url String @unique
  price Int
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  comments String
  license String
  tags Tag[]
  beatpacks Beatpack[]
}

model Beatpack {
  id Int @id @default(autoincrement())
  title String
  description String
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  beats Beat[]
  tags Tag[]
}

model Soundkit {
  id Int @id @default(autoincrement())
  title String
  description String
  picture_url String @unique
  file_url String @unique
  price Int
  viewers_ids Int[]
  likers_ids Int[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  license String
  beats String
  tags Tag[]
}

model Comment {
  id Int @id @default(autoincrement())
  text String
  author_id Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  author String
}

model Chat {
  id Int @id @default(autoincrement())
  messages String
  participants String
}

model Messages {
  id Int @id @default(autoincrement())
  text String
  author_id Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  chat String
  author String
}

model Notification {
  id Int @id @default(autoincrement())
  title String
  description String
  reciever String
  created_at DateTime @default(now())
}