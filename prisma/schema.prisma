generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Albums {
  id           Int      @id @default(autoincrement())
  cover_url    String
  album_name   String
  description  String
  plays_number Int
  duration     Int
  like         Boolean
  Tracks       Tracks[]
}

model Artists {
  id          Int      @id @default(autoincrement())
  artist_name String   @unique
  description String
  photo_url   String   @unique
  Beats       Beats[]
  Tags        Tags[]
  Tracks      Tracks[]
}

model Beatpacks {
  id            Int     @id @default(autoincrement())
  cover_url     String
  beatpack_name String
  description   String
  plays_number  Int
  like          Boolean
  Beats         Beats[]
}

model Beats {
  id            Int       @id @default(autoincrement())
  cover_url     String
  beat_name     String
  beatpack_name String
  listens       Int
  playtime      Int
  like          Boolean
  artist_id     Int
  producer_id   Int
  beatpack_id   Int
  file_url      String
  Artists       Artists   @relation(fields: [artist_id], references: [id])
  Beatpacks     Beatpacks @relation(fields: [beatpack_id], references: [id])
  Producers     Producers @relation(fields: [producer_id], references: [id])
}

model Producers {
  id            Int      @id @default(autoincrement())
  producer_name String   @unique
  description   String
  photo_url     String   @unique
  Beats         Beats[]
  Tags          Tags[]
  Tracks        Tracks[]
}

model Tags {
  id          Int       @id @default(autoincrement())
  tag_name    String
  description String
  artist_id   Int
  producer_id Int
  Artists     Artists   @relation(fields: [artist_id], references: [id])
  Producers   Producers @relation(fields: [producer_id], references: [id])
}

model Tracks {
  id          Int       @id @default(autoincrement())
  cover_url   String
  track_name  String
  listens     Int
  playtime    Int
  like        Boolean
  artist_id   Int
  producer_id Int
  album_id    Int
  file_url    String
  Albums      Albums    @relation(fields: [album_id], references: [id])
  Artists     Artists   @relation(fields: [artist_id], references: [id])
  Producers   Producers @relation(fields: [producer_id], references: [id])
}

